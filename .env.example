# ─────────────────────────────────────────────────────────────
# Sueteres RAG — Variáveis de ambiente
# Copie para .env e ajuste conforme o ambiente
# ─────────────────────────────────────────────────────────────

# ── Aplicação ─────────────────────────────────────────────────
APP_NAME="Sueteres RAG Assistant"
APP_VERSION="1.0.0"
APP_ENV=development           # development | production
DEBUG=false
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=sueteres-dev-key    # Troque em produção!

# ── LLM (Ollama) ──────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
LLM_PRIMARY_MODEL=mistral:7b-instruct-v0.3-q4_K_M
LLM_FALLBACK_MODEL=qwen2.5:3b-instruct-q4_K_M
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048
LLM_TIMEOUT_SECONDS=90
LLM_MAX_RETRIES=3

# ── Embeddings ────────────────────────────────────────────────
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DEVICE=cpu          # cpu | cuda | mps
EMBEDDING_BATCH_SIZE=32
MODELS_CACHE_DIR=./models

# ── ChromaDB ──────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=sueteres_corpus
CHROMA_DISTANCE_METRIC=cosine

# ── Document Store ────────────────────────────────────────────
SQLITE_DB_PATH=./document_store/sueteres.db

# ── Retrieval ─────────────────────────────────────────────────
RETRIEVAL_TOP_K_INITIAL=20
RETRIEVAL_TOP_K_FINAL=5
RETRIEVAL_SCORE_THRESHOLD=0.35    # Min score para resposta
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_DEVICE=cpu

# ── Chunking ──────────────────────────────────────────────────
CHUNK_SIZE_MIN=512
CHUNK_SIZE_TARGET=768
CHUNK_SIZE_MAX=1024
CHUNK_OVERLAP=128

# ── Corpus ────────────────────────────────────────────────────
CORPUS_DIR=./corpus

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=console            # console | json
LOG_FILE=./logs/sueteres.log
